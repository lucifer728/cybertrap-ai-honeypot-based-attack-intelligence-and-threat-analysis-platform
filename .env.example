# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Security
SECRET_KEY=your-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# Database
DATABASE_URL=postgresql://cybertrape:password123@localhost:5432/cybertrape_dev

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# JWT
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Honeypots
SSH_POT_PORT=2222
HTTP_POT_PORT=8080
FTP_POT_PORT=2121
TELNET_POT_PORT=2323
SMTP_POT_PORT=2525
DNS_POT_PORT=5353
MYSQL_POT_PORT=3307

# Logging
LOG_LEVEL=INFO

# Application
APP_NAME=CyberTrap-AI
APP_VERSION=1.0.0
